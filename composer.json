{
    "name": "rushing/laravel-data-schemas",
    "description": "Generate JSON Schemas from Laravel Data objects with validation attributes",
    "keywords": [
        "laravel",
        "json-schema",
        "spatie",
        "laravel-data",
        "validation",
        "schema-generation"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Stephen Rushing",
            "email": "stephen@rushing.dev"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "spatie/laravel-data": "^4.0|^5.0",
        "symfony/finder": "^6.0|^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Rushing\\LaravelDataSchemas\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rushing\\LaravelDataSchemas\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rushing\\LaravelDataSchemas\\LaravelDataSchemasServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}